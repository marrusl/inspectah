{
  "users": [
    {
      "classification": "human",
      "gid": 1000,
      "home": "/home/mark",
      "include": true,
      "name": "mark",
      "shell": "/bin/bash",
      "strategy": "kickstart",
      "uid": 1000
    }
  ],
  "groups": [
    {
      "gid": 1000,
      "include": true,
      "members": [],
      "name": "mark",
      "strategy": "kickstart"
    }
  ],
  "sudoers_rules": [
    "root\tALL=(ALL) \tALL",
    "%wheel\tALL=(ALL)\tALL"
  ],
  "ssh_authorized_keys_refs": [
    {
      "path": "/home/mark/.ssh/authorized_keys",
      "user": "mark"
    }
  ],
  "passwd_entries": [
    "mark:x:1000:1000:mark:/home/mark:/bin/bash"
  ],
  "shadow_entries": [
    "mark:REDACTED_SHADOW_HASH_1::0:99999:7:::"
  ],
  "group_entries": [
    "mark:x:1000:"
  ],
  "gshadow_entries": [
    "mark:!::"
  ],
  "subuid_entries": [
    "mark:100000:65536"
  ],
  "subgid_entries": [
    "mark:100000:65536"
  ]
}
