&#x2f;*# sourceMappingURL=patternfly.min.css.map *&#x2f;
</style>
  <style>&#x2f;* inspectah HTML audit report — custom styles
   All colors, spacing, and typography reference PatternFly 6 design tokens.
   No hardcoded hex values. *&#x2f;

&#x2f;* ── Breakpoint custom properties ────────────────────────────── *&#x2f;
:root {
  --report-bp-narrow: 600px;
  --report-bp-medium: 900px;
}

&#x2f;* ── Report header ───────────────────────────────────────────── *&#x2f;
.report-header {
  background: var(--pf-t--global--color--brand--default);
  color: var(--pf-t--global--text--color--on-brand--default);
  padding: var(--pf-t--global--spacer--lg) var(--pf-t--global--spacer--xl);
  font-family: var(--pf-t--global--font--family--heading);
}

.report-header h1 {
  font-size: var(--pf-t--global--font--size--2xl);
  font-weight: var(--pf-t--global--font--weight--heading--default);
  margin-bottom: var(--pf-t--global--spacer--xs);
}

.report-header .report-meta {
  font-size: var(--pf-t--global--font--size--sm);
  opacity: 0.85;
  display: flex;
  flex-wrap: wrap;
  gap: var(--pf-t--global--spacer--md);
}

&#x2f;* ── TOC navigation bar ──────────────────────────────────────── *&#x2f;
.report-toc {
  display: flex;
  flex-wrap: wrap;
  gap: var(--pf-t--global--spacer--sm);
  padding: var(--pf-t--global--spacer--md) var(--pf-t--global--spacer--xl);
  background: var(--pf-t--global--background--color--secondary--default);
  border-bottom: var(--pf-t--global--border--width--box--default) solid
    var(--pf-t--global--border--color--default);
}

.report-toc a {
  color: var(--pf-t--global--text--color--link--default);
  text-decoration: none;
  font-size: var(--pf-t--global--font--size--sm);
  padding: var(--pf-t--global--spacer--xs) var(--pf-t--global--spacer--sm);
  border-radius: var(--pf-t--global--border--radius--small);
}

.report-toc a:hover {
  background: var(--pf-t--global--background--color--primary--hover);
  color: var(--pf-t--global--text--color--link--hover);
}

@media (max-width: 600px) {
  .report-toc {
    display: none;
  }
}

&#x2f;* ── Summary cards ───────────────────────────────────────────── *&#x2f;
.report-cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--pf-t--global--spacer--md);
  padding: var(--pf-t--global--spacer--lg) var(--pf-t--global--spacer--xl);
}

.report-cards dl {
  background: var(--pf-t--global--background--color--primary--default);
  border: var(--pf-t--global--border--width--box--default) solid
    var(--pf-t--global--border--color--default);
  border-radius: var(--pf-t--global--border--radius--medium);
  padding: var(--pf-t--global--spacer--md);
}

.report-cards dt {
  font-size: var(--pf-t--global--font--size--xs);
  font-weight: var(--pf-t--global--font--weight--body--bold);
  color: var(--pf-t--global--text--color--subtle);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: var(--pf-t--global--spacer--xs);
}

.report-cards dd {
  font-size: var(--pf-t--global--font--size--2xl);
  font-weight: var(--pf-t--global--font--weight--heading--default);
  color: var(--pf-t--global--text--color--regular);
}

.report-cards dd.text-failed {
  color: var(--pf-t--global--color--status--danger--default);
}

.report-cards dd.text-degraded {
  color: var(--pf-t--global--color--status--warning--default);
}

.report-cards dt a {
  color: inherit;
  text-decoration: none;
}

.report-cards dt a:hover {
  text-decoration: underline;
}

@media (max-width: 900px) {
  .report-cards {
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  }
}

@media (max-width: 600px) {
  .report-cards {
    grid-template-columns: 1fr;
  }
}

&#x2f;* ── Sections (details&#x2f;summary) ──────────────────────────────── *&#x2f;
.report-section {
  border: var(--pf-t--global--border--width--box--default) solid
    var(--pf-t--global--border--color--default);
  border-radius: var(--pf-t--global--border--radius--medium);
  margin: var(--pf-t--global--spacer--md) var(--pf-t--global--spacer--xl);
}

.report-section summary {
  padding: var(--pf-t--global--spacer--md) var(--pf-t--global--spacer--lg);
  font-weight: var(--pf-t--global--font--weight--heading--default);
  font-size: var(--pf-t--global--font--size--lg);
  cursor: pointer;
  list-style: none;
  display: flex;
  align-items: center;
  gap: var(--pf-t--global--spacer--sm);
  background: var(--pf-t--global--background--color--secondary--default);
  border-radius: var(--pf-t--global--border--radius--medium);
}

.report-section summary::before {
  content: &quot;\25B6&quot;; &#x2f;* right-pointing triangle *&#x2f;
  font-size: var(--pf-t--global--font--size--xs);
  transition: transform 0.15s ease;
}

.report-section[open] summary::before {
  transform: rotate(90deg);
}

.report-section summary::-webkit-details-marker {
  display: none;
}

.report-section .section-body {
  padding: var(--pf-t--global--spacer--lg);
}

&#x2f;* Warning section — red left border accent *&#x2f;
.report-section--warning {
  border-left: 4px solid var(--pf-t--global--color--status--danger--default);
}

&#x2f;* Failed section — muted, data unavailable *&#x2f;
.report-section--failed {
  opacity: 0.7;
  border-left: 4px solid var(--pf-t--global--color--status--danger--default);
}

.report-section--failed summary {
  color: var(--pf-t--global--text--color--subtle);
}

&#x2f;* Degraded section — warning left border accent *&#x2f;
.report-section--degraded {
  border-left: 4px solid var(--pf-t--global--color--status--warning--default);
}

.failed-body {
  padding: var(--pf-t--global--spacer--lg);
  color: var(--pf-t--global--text--color--subtle);
  font-style: italic;
}

&#x2f;* ── Badges &#x2f; state indicators ───────────────────────────────── *&#x2f;
.badge {
  display: inline-flex;
  align-items: center;
  gap: var(--pf-t--global--spacer--xs);
  padding: var(--pf-t--global--spacer--xs) var(--pf-t--global--spacer--sm);
  border-radius: var(--pf-t--global--border--radius--pill);
  font-size: var(--pf-t--global--font--size--xs);
  font-weight: var(--pf-t--global--font--weight--body--bold);
  background: var(--pf-t--global--color--status--info--default);
  color: var(--pf-t--global--text--color--on-brand--default);
}

.badge-degraded {
  background: var(--pf-t--global--color--status--warning--default);
  color: var(--pf-t--global--text--color--status--on-warning--default);
}

.badge-failed {
  background: var(--pf-t--global--color--status--danger--default);
  color: var(--pf-t--global--text--color--on-brand--default);
}

&#x2f;* ── Filter inputs ───────────────────────────────────────────── *&#x2f;
.report-filter {
  display: flex;
  align-items: center;
  gap: var(--pf-t--global--spacer--sm);
  padding: var(--pf-t--global--spacer--sm) 0;
  margin-bottom: var(--pf-t--global--spacer--sm);
}

.report-filter label {
  font-size: var(--pf-t--global--font--size--sm);
  font-weight: var(--pf-t--global--font--weight--body--bold);
  color: var(--pf-t--global--text--color--regular);
  white-space: nowrap;
}

.report-filter input {
  flex: 1;
  max-width: 300px;
  padding: var(--pf-t--global--spacer--xs) var(--pf-t--global--spacer--sm);
  font-size: var(--pf-t--global--font--size--sm);
  font-family: var(--pf-t--global--font--family--body);
  border: var(--pf-t--global--border--width--box--default) solid
    var(--pf-t--global--border--color--default);
  border-radius: var(--pf-t--global--border--radius--small);
  background: var(--pf-t--global--background--color--primary--default);
  color: var(--pf-t--global--text--color--regular);
}

.report-filter input:focus {
  outline: 2px solid var(--pf-t--global--color--brand--default);
  outline-offset: 1px;
}

.report-filter .filter-count {
  font-size: var(--pf-t--global--font--size--xs);
  color: var(--pf-t--global--text--color--subtle);
  white-space: nowrap;
}

.filter-no-results {
  padding: var(--pf-t--global--spacer--lg);
  text-align: center;
  font-size: var(--pf-t--global--font--size--sm);
  color: var(--pf-t--global--text--color--subtle);
  font-style: italic;
}

&#x2f;* ── Tables ──────────────────────────────────────────────────── *&#x2f;
.report-section table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--pf-t--global--font--size--sm);
}

.report-section th,
.report-section td {
  padding: var(--pf-t--global--spacer--sm) var(--pf-t--global--spacer--md);
  text-align: left;
  border-bottom: var(--pf-t--global--border--width--box--default) solid
    var(--pf-t--global--border--color--default);
}

.report-section th {
  font-weight: var(--pf-t--global--font--weight--body--bold);
  color: var(--pf-t--global--text--color--subtle);
  background: var(--pf-t--global--background--color--secondary--default);
}

.report-section tbody tr:hover {
  background: var(--pf-t--global--background--color--primary--hover);
}

&#x2f;* ── Badge extras ───────────────────────────────────────────── *&#x2f;
.badge-extra {
  display: inline-flex;
  align-items: center;
  padding: var(--pf-t--global--spacer--xs) var(--pf-t--global--spacer--sm);
  border-radius: var(--pf-t--global--border--radius--pill);
  font-size: var(--pf-t--global--font--size--xs);
  font-weight: var(--pf-t--global--font--weight--body--bold);
  background: var(--pf-t--global--color--status--info--default);
  color: var(--pf-t--global--text--color--on-brand--default);
}

.badge-warning {
  background: var(--pf-t--global--color--status--warning--default);
  color: var(--pf-t--global--text--color--status--on-warning--default);
}

&#x2f;* ── Completeness banner ────────────────────────────────────── *&#x2f;
.completeness-banner {
  background: var(--pf-t--global--color--status--warning--default);
  color: var(--pf-t--global--text--color--status--on-warning--default);
  padding: var(--pf-t--global--spacer--md) var(--pf-t--global--spacer--xl);
  font-size: var(--pf-t--global--font--size--sm);
}

.completeness-banner p {
  margin: var(--pf-t--global--spacer--xs) 0;
}

.completeness-banner a {
  color: inherit;
  font-weight: var(--pf-t--global--font--weight--body--bold);
  text-decoration: underline;
}

&#x2f;* ── Source info bar ─────────────────────────────────────────── *&#x2f;
.source-info {
  padding: var(--pf-t--global--spacer--md) var(--pf-t--global--spacer--xl);
  background: var(--pf-t--global--background--color--secondary--default);
  border-bottom: var(--pf-t--global--border--width--box--default) solid
    var(--pf-t--global--border--color--default);
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: var(--pf-t--global--spacer--lg);
}

.source-info-primary {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: var(--pf-t--global--spacer--md);
}

.source-hostname {
  font-size: var(--pf-t--global--font--size--xl);
  font-weight: var(--pf-t--global--font--weight--heading--default);
  font-family: var(--pf-t--global--font--family--heading);
}

.source-os {
  font-size: var(--pf-t--global--font--size--sm);
  color: var(--pf-t--global--text--color--subtle);
}

.source-type {
  font-size: var(--pf-t--global--font--size--xs);
  color: var(--pf-t--global--text--color--subtle);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.source-info-fleet,
.source-info-baseline {
  font-size: var(--pf-t--global--font--size--sm);
}

.source-baseline-label {
  font-weight: var(--pf-t--global--font--weight--body--bold);
  color: var(--pf-t--global--text--color--subtle);
}

.source-baseline-ref {
  font-family: var(--pf-t--global--font--family--mono);
  font-size: var(--pf-t--global--font--size--xs);
  word-break: break-all;
}

&#x2f;* ── Report footer ──────────────────────────────────────────── *&#x2f;
.report-footer {
  padding: var(--pf-t--global--spacer--lg) var(--pf-t--global--spacer--xl);
  text-align: center;
  font-size: var(--pf-t--global--font--size--xs);
  color: var(--pf-t--global--text--color--subtle);
  border-top: var(--pf-t--global--border--width--box--default) solid
    var(--pf-t--global--border--color--default);
}

&#x2f;* ── Print ───────────────────────────────────────────────────── *&#x2f;
@media print {
  .report-toc,
  .report-filter {
    display: none;
  }

  .report-section {
    break-inside: avoid;
    margin: var(--pf-t--global--spacer--sm) 0;
  }

  .report-section[open] summary,
  .report-section summary {
    background: none;
  }

  &#x2f;* Force all details open in print *&#x2f;
  .report-section {
    display: block;
  }

  .report-cards {
    grid-template-columns: 1fr;
    padding: var(--pf-t--global--spacer--sm) 0;
  }
}
</style>
</head>
